'></a>[Visualization](#toc0_)\n- Horizontal bar chart showing composite risk scores\n- Color coding: Red (>0.6), Orange (0.3-0.6), Green (<0.3)\n- Value labels on all bars","metadata":{}},{"cell_type":"code","source":"# Create a composite risk score for each platform - FIXED VERSION\nplatform_risk_scores = pd.DataFrame({\n    'Avg_Screen_Time': df.groupby('platform_usage')['screen_time_before_sleep'].mean(),\n    'Pct_High_Risk': (df.groupby('platform_usage')['screen_time_before_sleep']\n                      .apply(lambda x: (x > 1.5).mean() * 100)),\n    'Avg_Sleep_Loss': 8 - df.groupby('platform_usage')['sleep_hours'].mean(),  # Assuming 8hrs recommended\n    'Pct_Sleep_Deprived': (df.groupby('platform_usage')['sleep_hours']\n                           .apply(lambda x: (x < 7).mean() * 100))\n})\n\nprint(\"Initial data:\")\nprint(platform_risk_scores.round(2))\n\n# Calculate composite risk score (normalized) - CORRECTED\n# First, identify the original columns (not the normalized ones)\noriginal_cols = ['Avg_Screen_Time', 'Pct_High_Risk', 'Avg_Sleep_Loss', 'Pct_Sleep_Deprived']\n\n# Create normalized versions\nfor col in original_cols:\n    min_val = platform_risk_scores[col].min()\n    max_val = platform_risk_scores[col].max()\n    if max_val != min_val:  # Avoid division by zero\n        platform_risk_scores[f'{col}_norm'] = (platform_risk_scores[col] - min_val) / (max_val - min_val)\n    else:\n        platform_risk_scores[f'{col}_norm'] = 0  # All values are the same\n\n# Calculate composite risk score using only the normalized columns\nnorm_cols = [f'{col}_norm' for col in original_cols]\nplatform_risk_scores['Composite_Risk'] = platform_risk_scores[norm_cols].mean(axis=1)\nplatform_risk_scores = platform_risk_scores.sort_values('Composite_Risk', ascending=False)\n\nprint(\"\\n\" + \"=\" * 80)\nprint(\"🚨 PLATFORM RISK ASSESSMENT DASHBOARD\")\nprint(\"=\" * 80)\nprint(platform_risk_scores[['Avg_Screen_Time', 'Pct_High_Risk', 'Avg_Sleep_Loss', 'Pct_Sleep_Depriv